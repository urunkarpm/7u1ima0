{
  "manifest_version": 3,
  "name": "Heading Level & Screenshot",
  "version": "1.0",
  "description": "Shows heading level on activation and captures a full page screenshot",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "action": {
    "default_title": "Show Heading & Capture Screenshot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["*.png"],
    "matches": ["<all_urls>"]
  }]
}
