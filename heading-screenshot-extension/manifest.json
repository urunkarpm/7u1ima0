{
  "manifest_version": 3,
  "name": "Heading Level & Screenshot",
  "version": "1.0",
  "description": "Shows heading level on activation and captures a full page screenshot",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "debugger"
  ],
  "action": {
    "default_title": "Show Heading & Capture Screenshot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
